{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecureRails Safety Ledger",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "raw_secret_leak_count",
    "external_target_scan_count",
    "exploit_execution_count",
    "malware_generation_count",
    "social_engineering_content_count",
    "unsafe_automerge_count",
    "critical_safety_incidents"
  ],
  "properties": {
    "schema_version": {
      "const": "securerails.safety_ledger.v1"
    },
    "run_id": {
      "type": "string"
    },
    "raw_secret_leak_count": {
      "type": "integer",
      "minimum": 0
    },
    "external_target_scan_count": {
      "type": "integer",
      "minimum": 0
    },
    "exploit_execution_count": {
      "type": "integer",
      "minimum": 0
    },
    "malware_generation_count": {
      "type": "integer",
      "minimum": 0
    },
    "social_engineering_content_count": {
      "type": "integer",
      "minimum": 0
    },
    "unsafe_automerge_count": {
      "type": "integer",
      "minimum": 0
    },
    "critical_safety_incidents": {
      "type": "integer",
      "minimum": 0
    },
    "policy_violations": {
      "type": "integer",
      "minimum": 0
    },
    "redaction_status": {
      "type": "string"
    },
    "claim_boundary_status": {
      "type": "string"
    }
  }
}
