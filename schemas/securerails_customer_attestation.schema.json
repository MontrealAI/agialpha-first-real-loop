{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecureRails Customer Use Attestation",
  "type": "object",
  "required": [
    "schema_version",
    "customer_name",
    "deployment_id",
    "attestations"
  ],
  "properties": {
    "schema_version": {
      "const": "securerails.customer_attestation.v1"
    },
    "customer_name": {
      "type": "string",
      "minLength": 1
    },
    "deployment_id": {
      "type": "string",
      "minLength": 1
    },
    "attestations": {
      "type": "object",
      "required": [
        "no_hr_worker_evaluation",
        "no_profiling_natural_persons",
        "no_critical_infrastructure_safety_component",
        "human_review_required",
        "automerge_disabled",
        "no_offensive_cyber",
        "no_raw_secret_output",
        "not_security_certification",
        "material_changes_rescreened"
      ],
      "properties": {
        "no_hr_worker_evaluation": {
          "const": true
        },
        "no_profiling_natural_persons": {
          "const": true
        },
        "no_critical_infrastructure_safety_component": {
          "const": true
        },
        "human_review_required": {
          "const": true
        },
        "automerge_disabled": {
          "const": true
        },
        "no_offensive_cyber": {
          "const": true
        },
        "no_raw_secret_output": {
          "const": true
        },
        "not_security_certification": {
          "const": true
        },
        "material_changes_rescreened": {
          "const": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}