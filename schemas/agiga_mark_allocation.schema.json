{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AGIGA MARK Allocation",
  "type": "object",
  "required": [
    "schema_version",
    "allocation_id",
    "nova_seed_id",
    "allocated_budget_proxy",
    "review_priority",
    "risk_tier",
    "validator_required",
    "replay_required",
    "falsification_required",
    "human_review_required_for_promotion",
    "promotion_threshold",
    "rejection_reason_if_any"
  ],
  "properties": {
    "schema_version": {
      "const": "agialpha.agiga.mark_allocation.v1"
    },
    "allocation_id": {
      "type": "string"
    },
    "nova_seed_id": {
      "type": "string"
    },
    "allocated_budget_proxy": {
      "type": "number"
    },
    "review_priority": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "risk_tier": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "validator_required": {
      "type": "boolean"
    },
    "replay_required": {
      "type": "boolean"
    },
    "falsification_required": {
      "type": "boolean"
    },
    "human_review_required_for_promotion": {
      "type": "boolean"
    },
    "promotion_threshold": {
      "type": "object"
    },
    "rejection_reason_if_any": {
      "type": "string"
    }
  }
}
