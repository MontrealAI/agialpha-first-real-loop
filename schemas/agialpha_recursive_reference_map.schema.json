{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://montrealai.github.io/agialpha-first-real-loop/schemas/agialpha_recursive_reference_map.schema.json",
  "title": "AGI ALPHA Recursive Reference Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "references",
    "label",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "agialpha.recursive_reference_map.v1"
    },
    "references": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "family",
              "label",
              "status"
            ],
            "properties": {
              "family": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "context_only",
                  "implemented_with_evidence"
                ]
              }
            }
          }
        ]
      }
    },
    "usage_boundary": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 1
    }
  }
}
