{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecureRails Work Vault",
  "type": "object",
  "required": [
    "vault_id",
    "run_id",
    "created_at",
    "defensive_scope"
  ],
  "properties": {
    "vault_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "defensive_scope": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
