  "allowed_negative_boundaries": [
    "does not claim",
    "not empirical SOTA",
    "not achieved AGI",
    "not achieved ASI",
    "not safe autonomy",
    "not security certification",
    "not offensive cyber",
    "not an investment product"
  ]
